{
  "manifest_version": 3,
  "name": "Grammar Check SLM",
  "version": "1.1.0",
  "description": "Private, on-device grammar and spell checking powered by local small language models with WebGPU acceleration.",
  "homepage_url": "https://github.com/techtocore/Grammar-check-SLM",
  "minimum_chrome_version": "116",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "offscreen",
    "scripting",
    "contextMenus",
    "activeTab",
    "clipboardWrite"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_origin_as_fallback": true
    }
  ],
  "action": {
    "default_title": "Grammar Check SLM",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'none'; connect-src 'self' https://huggingface.co https://*.huggingface.co https://hf.co https://*.hf.co https://*.xethub.hf.co"
  }
}

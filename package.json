{
  "name": "grammar-check-slm",
  "version": "1.0.0",
  "description": "Privacy-first, on-device grammar checking browser extension powered by a local Small Language Model (Transformers.js) with WebGPU acceleration.",
  "type": "module",
  "author": "techtocore",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/chrome": "^0.2.0",
    "@types/node": "^26.0.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "html-webpack-plugin": "^5.6.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.4",
    "ts-loader": "^9.6.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0"
  }
}
